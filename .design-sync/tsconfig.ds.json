{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "baseUrl": "../apps/web/src",
    "paths": {
      "@/*": ["*"]
    }
  },
  "include": [
    "ui-entry.ts",
    "../apps/web/src/components/ui/**/*.tsx"
  ]
}
