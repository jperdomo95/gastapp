{
  "name": "@gastapp/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "prisma:generate": "dotenv -e ../../.env -- prisma generate",
    "prisma:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "prisma:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "prisma:seed": "dotenv -e ../../.env -- node --import tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "dotenv -e ../../.env -- node --import tsx prisma/seed.ts"
  },
  "dependencies": {
    "@gastapp/types": "workspace:*",
    "@nestjs/common": "10.4.7",
    "@nestjs/config": "3.3.0",
    "@nestjs/core": "10.4.7",
    "@nestjs/jwt": "10.2.0",
    "@nestjs/passport": "10.0.3",
    "@nestjs/platform-express": "10.4.7",
    "@nestjs/swagger": "8.0.5",
    "@prisma/client": "5.22.0",
    "argon2": "0.41.1",
    "cookie-parser": "1.4.7",
    "csv-parse": "6.2.1",
    "helmet": "8.0.0",
    "nestjs-zod": "3.0.0",
    "passport": "0.7.0",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "10.4.7",
    "@nestjs/schematics": "10.2.3",
    "@nestjs/testing": "10.4.7",
    "@types/cookie-parser": "1.4.7",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/node": "20.17.6",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "dotenv-cli": "11.0.0",
    "jest": "29.7.0",
    "prisma": "5.22.0",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
