# --- Postgres ---
POSTGRES_USER=gastapp
POSTGRES_PASSWORD=gastapp_dev
POSTGRES_DB=gastapp
POSTGRES_PORT=5432

# --- API ---
API_PORT=3001
DATABASE_URL=postgresql://gastapp:gastapp_dev@localhost:5432/gastapp?schema=public

JWT_ACCESS_SECRET=replace-me-with-a-long-random-string
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

WEB_ORIGIN=http://localhost:5173

# --- Web ---
VITE_API_URL=http://localhost:3001
# Set to "false" to hide the "Continue with Google" button (e.g. in production
# while Google OAuth is not configured). Build-time variable.
VITE_ENABLE_GOOGLE=true
